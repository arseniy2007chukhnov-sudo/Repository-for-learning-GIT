.PHONY: create-structure test-pytest install-dep test-pytest


create-structure:
    mkdir src docs tests
    touch docs/DOMAIN.md
    touch src/.gitkeep
    touch tests/.gitkeep
    touch requirements.txt setup.py README.md

install:
    pip install -e

install-dep:
    pip install -r requirements


test-pytest:
    pytest

test: test-pytest


